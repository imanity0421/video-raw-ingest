# 可选：LLM 插件（OpenAI 兼容 API）。复制为 `.env` 后填写；勿将真实密钥提交到 Git。
# 加载顺序：仓库根 `.env` → 环境变量 RAW_INGEST_DOTENV → `llm` 子命令的 `--env-file`

# 第三方聚合（如 4Z）必须设置 base，否则请求会发到 api.openai.com，与聚合平台 key 不匹配
OPENAI_API_BASE=https://4zapi.com/v1

OPENAI_API_KEY=

# 在 4Z 控制台选用模型名（以平台文档为准），例如：
# OPENAI_CHAT_MODEL=gpt-4o-mini

# 可选：在加载仓库 .env 之后，再加载另一份 env（覆盖同名变量）
# RAW_INGEST_DOTENV=/path/to/extra.env

# 若从已安装包路径无法定位仓库根，可显式指定（一般不需要）
# RAW_INGEST_REPO_ROOT=/root/video-raw-ingest
